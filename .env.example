VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Vollständige Redirect-URL für Passwort-Reset-Links.
# Auf Vercel (Production & Preview) setzen — z.B.
#   VITE_PASSWORD_RESET_REDIRECT="https://forms.datastruct.ch/reset-password"
# Diese URL muss im Supabase Dashboard unter
# Authentication → URL Configuration → Redirect URLs eingetragen sein.
VITE_PASSWORD_RESET_REDIRECT="https://forms.datastruct.ch/reset-password"
